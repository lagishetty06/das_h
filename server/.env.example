# =====================================
# DASH Backend — Environment Variables
# =====================================

# MongoDB Atlas connection string
DB_URL=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/?appName=Cluster0

# JWT secret key (any random long string)
JWT_SECRET=my_custom_random_string_for_backend

# Email (for OTP verification and reminders)
EMAIL_SERVICE=gmail
EMAIL_USER=yourgmail@gmail.com
EMAIL_PASS=your_gmail_app_password

# Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key

# Server port (leave as 4000 or Render sets this automatically)
PORT=4000
